ai:
  # Active provider: claude | openai | openrouter | local
  provider: openrouter

  claude:
    api_key: "YOUR_ANTHROPIC_API_KEY"
    model: "claude-sonnet-4-6"

  openai:
    api_key: "YOUR_OPENAI_API_KEY"
    model: "gpt-4o"

  openrouter:
    api_key: "YOUR_OPENROUTER_API_KEY"
    base_url: "https://openrouter.ai/api/v1"
    model: "anthropic/claude-sonnet-4-5"

  local:
    base_url: "http://localhost:11434/v1"
    model: "llama3.1:8b"
    api_key: "not-needed"

server:
  port: 5001
  host: "0.0.0.0"
  max_upload_mb: 2048
  database_path: "data/mobiletrace.db"
  cases_dir: "data/cases"

analysis:
  # Maximum records sent to the LLM per artifact type.
  # Raise these on powerful hardware; lower them to reduce API costs.
  max_messages_per_platform: 500
  max_calls: 300
  max_contacts: 300
